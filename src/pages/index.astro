---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Oumaima Elghalbouni | Data Engineering Student',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>

  <!-- Hero Section -->
  <Hero
    actions={[
      { text: 'View Projects', href: '#projects' },
      { text: 'Contact Me', href: '#contact' },
    ]}
    image={{ src: '~/assets/images/hero-image.png', alt: 'Oumaima Elghalbouni' }}
  >
    <Fragment slot="title">
      Oumaima Elghalbouni
    </Fragment>

    <Fragment slot="subtitle">
      Data Engineering Student | Python, SQL, PyQt & Web Development  
      I create data-driven applications and solutions for real-world problems.
    </Fragment>
  </Hero>

  <!-- Philosophy / Note -->
  <Note title="Philosophy:" description="Simplicity, Efficiency, and High Impact" />

  <!-- About Me -->
  <Content
    isReversed
    tagline="About Me"
    title="Who I am"
    items={[
      {
        title: 'Data Engineering Student',
        description: 'Currently pursuing a degree in Data Engineering. Passionate about Python, SQL, data visualization, and building practical applications.',
      },
      {
        title: 'Web & Application Development',
        description: 'Experience developing desktop and web applications including hotel management systems, medical data management, and weather apps.',
      },
      {
        title: 'Problem Solver',
        description: 'I enjoy analyzing data, optimizing solutions, and creating applications that make processes efficient.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1600132806370-bf17e65e942f?auto=format&fit=crop&w=2070&q=80',
      alt: 'About Me Image',
    }}
  />

  <!-- Projects Section -->
  <Features
    id="projects"
    tagline="Projects"
    title="Selected Projects"
    subtitle="A showcase of some of the applications and solutions I have built"
    items={[
      {
        title: 'Medical Data Management System',
        description: 'A web and desktop application to manage patient records, analyze disease trends, and generate statistical visualizations. Built with Python (Pandas, Matplotlib), PHP, and MySQL.',
        icon: 'tabler:medical-cross',
      },
      {
        title: 'Weather Application',
        description: 'A desktop application using PyQt5 to display weather data and forecasts with real-time updates and graphical icons. Supports multiple cities and search suggestions.',
        icon: 'tabler:cloud-snow',
      },
      {
        title: 'SQL Query Optimization Project',
        description: 'Analyzed and optimized query performance on a stock management database using views and materialized views, reducing execution times significantly.',
        icon: 'tabler:database',
      },
      {
        title: 'Hotel Reservation Management System',
        description: 'A desktop application in C for managing hotel rooms, employees, and reservations with multiple roles and detailed statistics.',
        icon: 'tabler:building-skyscraper',
      },
    ]}
  />

  <!-- Skills Section -->
  <Features2
    title="Skills & Tools"
    subtitle="Technologies I work with"
    tagline="Skills"
    items={[
      { title: 'Programming', description: 'Python, C, JavaScript, SQL', icon: 'tabler:code' },
      { title: 'Data & Analytics', description: 'Pandas, NumPy, Matplotlib, Power BI', icon: 'tabler:chart-bar' },
      { title: 'Web & Desktop', description: 'PyQt5, HTML, CSS, PHP, MySQL', icon: 'tabler:desktop' },
      { title: 'Version Control', description: 'Git & GitHub', icon: 'tabler:git-branch' },
    ]}
  />

  <!-- Call to Action -->
  <CallToAction
    actions={[
      { variant: 'primary', text: 'Contact Me', href: '#contact', icon: 'tabler:mail' },
      { text: 'View GitHub', href: 'https://github.com/elghalbouni-oumaima', target: '_blank', icon: 'tabler:brand-github' },
    ]}
  >
    <Fragment slot="title">
      Let&apos;s Build Together
    </Fragment>
    <Fragment slot="subtitle">
      I’m currently looking for opportunities to contribute to data-driven projects and grow as a Data Engineer.
    </Fragment>
  </CallToAction>

</Layout>
