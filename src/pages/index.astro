---
import Layout from "~/layouts/PageLayout.astro";

import Hero from "~/components/widgets/Hero.astro";
import Note from "~/components/widgets/Note.astro";
import Features from "~/components/widgets/Features.astro";
import Content from "~/components/widgets/Content.astro";
import CallToAction from "~/components/widgets/CallToAction.astro";

const metadata = {
  title: "Oumaima Elghalbouni | Data Engineering Portfolio",
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- HERO -->
  <Hero
    actions={[
      {
        variant: "primary",
        text: "Download CV",
        href: "/resume.pdf",
        target: "_blank",
        icon: "tabler:file-download",
      },
      { text: "View Projects", href: "#projects" },
    ]}
    image={{ src: "~/assets/images/hero-image.png", alt: "Oumaima Portfolio" }}
  >
    <Fragment slot="title">
      Building <span class="text-accent dark:text-white"
        >Data-Driven Applications</span
      > & Analytical Solutions
    </Fragment>

    <Fragment slot="subtitle">
      <span class="font-semibold text-blue-600">Oumaima El Ghalbouni</span> — Data
      Engineering Student Passionate about transforming raw data into insights using
      <span class="font-semibold">Python, SQL, and Data Visualization</span>,
      and developing real-world applications combining data and software.
    </Fragment>
  </Hero>

  <!-- NOTE -->
  <Note
    title="Mission:"
    description="Designing and developing data-driven systems that collect, process, analyze, and visualize data to support decision-making."
  />

  <!-- FEATURES / SKILLS -->
  <Features
    id="skills"
    tagline="Technical Stack"
    title="My Skills & Technologies"
    subtitle="A practical overview of the tools and technologies I use in my projects."
    items={[
      {
        title: "Data Analysis & Visualization",
        description:
          "Analyzing and visualizing data using Pandas, NumPy, and Matplotlib to extract meaningful insights.",
        icon: "tabler:chart-bar",
      },
      {
        title: "Database Management",
        description:
          "Designing and querying relational databases with MySQL and SQL, including joins, optimization, and data modeling.",
        icon: "tabler:database",
      },
      {
        title: "Python Development",
        description:
          "Developing data applications and automation scripts using Python (Tkinter, PyQt5, Flask).",
        icon: "tabler:brand-python",
      },
      {
        title: "Machine Learning",
        description:
          "Applying preprocessing techniques and building predictive models for data-driven decision making.",
        icon: "tabler:brain",
      },
      {
        title: "Web Development",
        description:
          "Building dynamic web applications using PHP, HTML, CSS, and integrating them with MySQL databases.",
        icon: "tabler:world",
      },
      {
        title: "Tools & Environment",
        description:
          "Working with Git, GitHub, Power BI, Linux, and modern development environments.",
        icon: "tabler:tool",
      },
    ]}
  />

  <!-- ABOUT -->
  <Content
    id="about"
    isReversed
    tagline="Profile"
    title="About Me & Academic Journey"
    items={[
      {
        title: "Data Engineering Student",
        description:
          "Currently in my second year, building strong foundations in programming, databases, and data analysis.",
      },
      {
        title: "Project-Based Learning",
        description:
          "Developed projects such as medical data management systems, dashboards, and data analysis tools.",
      },
      {
        title: "Goal",
        description:
          "Seeking an internship to apply my skills in data engineering, data analysis, and real-world problem solving.",
      },
    ]}
    image={{
      src: "https://images.unsplash.com/photo-1519389950473-47ba0277781c?auto=format&fit=crop&w=2070&q=80",
      alt: "Collaboration",
    }}
  >
    <Fragment slot="content">
      <h3
        class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2"
      >
        From Data to Real Applications
      </h3>
      I enjoy building complete solutions — from data collection and storage to analysis,
      visualization, and user interaction through applications.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <Features
  id="experience"
  tagline="Experience"
  title="Professional Experience"
  subtitle="My hands-on experience through internships and real-world projects."
  items={[
    {
      title: 'Data Analyst Intern - Terra Nova EBS, Morocco',
      description: 'Designed and developed interactive dashboards for the Procurement Department to analyze purchasing data and support decision-making using Power BI and Excel.',
      icon: 'tabler:briefcase',
    },
    {
      title: 'Web Development Intern - Provincial Hospital Center Med VI, Al Hoceima, Morocco',
      description: 'Designed and implemented admin and employee modules of a web application to digitalize the radiology department’s operations.',
      icon: 'tabler:school',
    },
  ]}
/>
  <!-- STEPS -->
  <!-- <Steps
    title="My Learning Journey"
    items={[
      {
        title: 'Step 1: <span class="font-medium">Strong Foundations</span>',
        description:
          "Learning programming, SQL, and data analysis fundamentals.",
        icon: "tabler:school",
      },
      {
        title: 'Step 2: <span class="font-medium">Building Projects</span>',
        description:
          "Developing real-world applications combining Python, databases, and web technologies.",
        icon: "tabler:code",
      },
      {
        title: 'Step 3: <span class="font-medium">Advanced Topics</span>',
        description:
          "Exploring machine learning, data engineering concepts, and data pipelines.",
        icon: "tabler:database",
      },
      {
        title: "Ready for Internship",
        icon: "tabler:check",
      },
    ]}
    image={{
      src: "https://images.unsplash.com/photo-1616198814651-e71f960c3180?auto=format&fit=crop&w=987&q=80",
      alt: "Growth",
    }}
  /> -->
  <section id="timeline" class="py-16 bg-gray-50 dark:bg-gray-900">
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="text-3xl font-bold text-center mb-10">Education</h2>

    <div class="relative border-l-2 border-blue-600 dark:border-blue-400 ml-4">
      
      <!-- Timeline Item 1 -->
      <div class="mb-10 ml-6">
        <span class="absolute -left-4 top-0 flex items-center justify-center w-8 h-8 rounded-full bg-blue-600 dark:bg-blue-400 ring-4 ring-white dark:ring-gray-900">
          <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2z" />
          </svg>
        </span>
        <h3 class="text-xl font-semibold text-gray-900 dark:text-white">Engineering Cycle – Data Engineering</h3>
        <span class="text-sm text-blue-600 dark:text-blue-400">2025 – Present</span>
        <p class="text-gray-500 dark:text-gray-300">
          <strong>National School of Applied Sciences (ENSAH)</strong> — 2nd year · Specialization in Data Engineering and distributed systems.
        </p>
      </div>

      <!-- Timeline Item 2 -->
      <div class="mb-10 ml-6">
        <span class="absolute -left-4 top-0 flex items-center justify-center w-8 h-8 rounded-full bg-pink-600 dark:bg-pink-400 ring-4 ring-white dark:ring-gray-900">
          <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2z" />
          </svg>
        </span>
        <h3 class="text-xl font-semibold text-gray-900 dark:text-white">Baccalaureate in Physics and Chemistry (French Option)</h3>
        <span class="text-sm text-purple-600 dark:text-purple-400">2021 – 2022</span>
        <p class="text-gray-500 dark:text-gray-300">
          <strong>Rif High School, Al Hoceima</strong>
        </p>
      </div>

    </div>
  </div>
</section>

  <!-- PROJECTS -->
  <section id="projects" class="py-16">
    <div class="max-w-6xl mx-auto px-4">
      
      <h2 class="text-5xl font-bold text-center mb-4">My Projects</h2>
      <p class="text-center text-gray-500 mb-10">
        A selection of projects showcasing my skills in data engineering, data analysis, and development.
      </p>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- PROJECT: TAASIM -->
        <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-lg overflow-hidden">
          <img src="/images/taasim.png" alt="TaaSim Platform" class="w-full h-48 object-cover" />

          <div class="p-5">
            <h3 class="text-xl font-bold mb-2">TaaSim — Urban Mobility Data Platform</h3>
            <p class="text-sm text-gray-500 mb-3">
              Big Data • Spark • Kafka • Machine Learning
            </p>

            <p class="mb-4">
              Designed a real-time urban mobility platform for Casablanca to optimize transportation systems. 
              Processes GPS streams and trip data to analyze demand patterns and improve city mobility using big data and machine learning.
            </p>

            <a href="https://github.com/YOUR_USERNAME/taasim"
              target="_blank"
              class="inline-block bg-blue-600 text-white px-4 py-2 rounded-lg text-sm hover:bg-blue-700">
              View Project
            </a>
          </div>
        </div>

        <!-- PROJECT: JOB PLATFORM -->
        <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-lg overflow-hidden">
          <img src="/images/job-platform.jpg" alt="Job Platform" class="w-full h-48 object-cover" />

          <div class="p-5">
            <h3 class="text-xl font-bold mb-2">Job Platform — Recruitment Web Application</h3>
            <p class="text-sm text-gray-500 mb-3">
              PHP • MySQL • JavaScript • Web Development
            </p>

            <p class="mb-4">
              Developed a web platform connecting employers and candidates. 
              Includes job posting, application management, and user authentication with a dynamic and responsive interface.
            </p>

            <a href="https://github.com/YOUR_USERNAME/job-platform"
              target="_blank"
              class="inline-block bg-blue-600 text-white px-4 py-2 rounded-lg text-sm hover:bg-blue-700">
              View Project
            </a>
          </div>
        </div>
        <!-- PROJECT 1 -->
        <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-lg overflow-hidden">
          <img src="/images/data-warehouse.png" alt="Data Warehouse" class="w-full h-48 object-cover" />

          <div class="p-5">
            <h3 class="text-xl font-bold mb-2">End-to-End Data Warehouse</h3>
            <p class="text-sm text-gray-500 mb-3">
              SQL • Airflow • Power BI • ETL
            </p>

            <p class="mb-4">
              Designed a complete data warehouse with ETL pipelines, data modeling, and dashboards for business insights.
            </p>

            <a href="https://github.com/elghalbouni-oumaima/End-to-End-Data-Warehouse-with-SQL"
              target="_blank"
              class="inline-block bg-blue-600 text-white px-4 py-2 rounded-lg text-sm hover:bg-blue-700">
              View Project
            </a>
          </div>
        </div>

        <!-- PROJECT 2 -->
        <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-lg overflow-hidden">
          <img src="/images/mongodb.png" alt="MongoDB Project" class="w-full h-48 object-cover" />

          <div class="p-5">
            <h3 class="text-xl font-bold mb-2">FHV Trip Data Optimization</h3>
            <p class="text-sm text-gray-500 mb-3">
              MongoDB • Spark • Hadoop • Big Data
            </p>

            <p class="mb-4">
              Optimized large-scale trip data using MongoDB, Spark, and Hadoop to improve performance and analytics.
            </p>

            <a href="https://github.com/elghalbouni-oumaima/fhv-tripdata-mongodb-optimization"
              target="_blank"
              class="inline-block bg-blue-600 text-white px-4 py-2 rounded-lg text-sm hover:bg-blue-700">
              View Project
            </a>
          </div>
        </div>

        <!-- PROJECT 3 -->
        <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-lg overflow-hidden">
          <img src="/images/medical.png" alt="Medical System" class="w-full h-48 object-cover" />

          <div class="p-5">
            <h3 class="text-xl font-bold mb-2">Medical Data Management System</h3>
            <p class="text-sm text-gray-500 mb-3">
              Python • MySQL • PHP • Data Analysis
            </p>

            <p class="mb-4">
              Built a system to manage patient data and generate statistical insights using Python and web technologies.
            </p>

            <a href="https://github.com/elghalbouni-oumaima/disease-management-system"
              target="_blank"
              class="inline-block bg-blue-600 text-white px-4 py-2 rounded-lg text-sm hover:bg-blue-700">
              View Project
            </a>
          </div>
        </div>

        <!-- PROJECT 4 -->
        <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-lg overflow-hidden">
          <img src="/images/weather.png" alt="Weather App" class="w-full h-48 object-cover" />

          <div class="p-5">
            <h3 class="text-xl font-bold mb-2">Weather Application</h3>
            <p class="text-sm text-gray-500 mb-3">
              Python • PyQt5 • API • UI
            </p>

            <p class="mb-4">
              Developed a desktop weather application with a modern UI using PyQt5. Integrated a weather API to display real-time data with dynamic icons and city search functionality.
            </p>

            <a href="https://github.com/elghalbouni-oumaima/Weather-Application"
              target="_blank"
              class="inline-block bg-blue-600 text-white px-4 py-2 rounded-lg text-sm hover:bg-blue-700">
              View Project
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- CERTIFICATIONS -->
<!-- CERTIFICATIONS -->
<section id="certifications" class="py-16 bg-gray-50 dark:bg-gray-900">
  <div class="max-w-6xl mx-auto px-4">

    <h2 class="text-3xl font-bold text-center mb-10">Achievements & Certifications</h2>

    <p class="text-center text-gray-500 mb-10 max-w-2xl mx-auto">
      My journey in Data Engineering is driven by continuous learning. Here are a few certifications that showcase my expertise in cloud, machine learning, and data visualization.
    </p>

    <div class="space-y-6">
      
      <!-- CERTIFICATE 1 -->
      <div class="flex flex-col md:flex-row bg-purple-800 dark:bg-purple-700 rounded-xl overflow-hidden shadow-lg">
        <div class="flex-1 p-6 text-white">
          <h3 class="text-xl font-bold mb-2">Introduction to Docker</h3>
          <p class="mb-4">
            Gained hands-on experience in containerizing applications and managing images/containers for scalable deployments through DataCamp.
          </p>
          <div class="flex items-center justify-between">
            <span class="font-semibold text-purple-200">DevOps • 2026</span>
            <a href="/certificates/certificate-IntroDocker.pdf" target="_blank" class="bg-white text-purple-800 px-4 py-2 rounded-lg text-sm hover:bg-gray-200">
              Download PDF
            </a>
          </div>
        </div>
        <img src="/images/certificates/docker.png" alt="Docker Certificate" class="w-full md:w-48 object-cover"/>
      </div>

      <!-- CERTIFICATE 2 -->
      <div class="flex flex-col md:flex-row bg-purple-800 dark:bg-purple-700 rounded-xl overflow-hidden shadow-lg">
        <div class="flex-1 p-6 text-white">
          <h3 class="text-xl font-bold mb-2">Supervised Learning with Scikit-Learn</h3>
          <p class="mb-4">
            Built and evaluated predictive models using regression and classification algorithms for data-driven insights on DataCamp.
          </p>
          <div class="flex items-center justify-between">
            <span class="font-semibold text-purple-200">Machine Learning • 2025</span>
            <a href="/certificates/certificate supervisedLearning.pdf" target="_blank" class="bg-white text-purple-800 px-4 py-2 rounded-lg text-sm hover:bg-gray-200">
              Download PDF
            </a>
          </div>
        </div>
        <img src="/images/certificates/scikit-learn.png" alt="Scikit-Learn Certificate" class="w-full md:w-48 object-cover"/>
      </div>

      <!-- CERTIFICATE 3 -->
      <div class="flex flex-col md:flex-row bg-purple-800 dark:bg-purple-700 rounded-xl overflow-hidden shadow-lg">
        <div class="flex-1 p-6 text-white">
          <h3 class="text-xl font-bold mb-2">Understanding Artificial Intelligence</h3>
          <p class="mb-4">
            Mastered foundational AI concepts, ethics, and practical applications in business and technology via DataCamp.
          </p>
          <div class="flex items-center justify-between">
            <span class="font-semibold text-purple-200">AI • 2025</span>
            <a href="/certificates/certificateUnderstanding of artificial intelligence.pdf" target="_blank" class="bg-white text-purple-800 px-4 py-2 rounded-lg text-sm hover:bg-gray-200">
              Download PDF
            </a>
          </div>
        </div>
        <img src="/images/certificates/ai.png" alt="AI Certificate" class="w-full md:w-48 object-cover"/>
      </div>

    </div>
  </div>
</section>
  <!-- CTA -->
  <CallToAction
    actions={[
      {
        variant: "primary",
        text: "Contact Me on LinkedIn",
        href: "https://www.linkedin.com/in/el-ghalbouni-oumaima-a73a26331/",
        target: "_blank",
        icon: "tabler:brand-linkedin",
      },
    ]}
  >
    <Fragment slot="title">
      Let's build something <span class="text-accent">data-driven</span> together.
    </Fragment>

    <Fragment slot="subtitle">
      I am open to internship opportunities and collaborations in Data
      Engineering, Data Analysis, and Data Science, aiming to apply my skills to
      real-world projects.
    </Fragment>
  </CallToAction>
</Layout>
