---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Oumaima Elghalbouni | Data Engineering Portfolio',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Download CV',
        href: '/resume.pdf',
        target: '_blank',
        icon: 'tabler:file-download',
      },
      { text: 'View Projects', href: '#projects' },
    ]}
    image={{ src: '~/assets/images/hero-image.png', alt: 'Oumaima Elghalbouni Portfolio' }}
  >
    <Fragment slot="title">
      Building Scalable <span class="text-accent dark:text-white">Data Solutions</span> & Distributed Systems
    </Fragment>

    <Fragment slot="subtitle">
      <span class="font-semibold text-blue-600">Oumaima Elghalbouni</span> — 2nd Year Data Engineering Student. 
      Focused on Big Data orchestration with <span class="font-semibold">Apache Airflow</span>, 
      cloud infrastructure on <span class="font-semibold">OCI</span>, and automated development workflows.
    </Fragment>
  </Hero>

  <Note title="Mission:" description="Transforming raw data into actionable insights through robust ETL pipelines and cloud-native architecture." />

  <Features
    id="skills"
    tagline="Technical Stack"
    title="Data Engineering & Cloud Tools"
    subtitle="A comprehensive look at the technologies I use to build and orchestrate data-driven applications."
    items={[
      {
        title: 'Big Data Orchestration',
        description: 'Building and monitoring complex ETL pipelines using Apache Airflow, Hadoop (HDFS), and Trino.',
        icon: 'tabler:settings-automation',
      },
      {
        title: 'Cloud Infrastructure',
        description: 'Currently specializing in Oracle Cloud Infrastructure (OCI). Working toward Foundations Associate certification.',
        icon: 'tabler:cloud-computing',
      },
      {
        title: 'Machine Learning',
        description: 'Mastering preprocessing techniques (SMOTE), optimization algorithms (Adam, BFGS), and model performance tuning.',
        icon: 'tabler:brain',
      },
      {
        title: 'DevOps & Automation',
        description: 'Automating development with Docker Compose and managing CI/CD pipelines via GitHub Actions.',
        icon: 'tabler:container',
      },
      {
        title: 'Programming',
        description: 'Proficient in Python, SQL, and PHP for back-end development and data manipulation.',
        icon: 'tabler:code',
      },
      {
        title: 'Modern Web Development',
        description: 'Building high-performance portfolios and applications using Astro, Tailwind CSS, and GitHub Pages.',
        icon: 'tabler:brand-astro',
      },
    ]}
  />

  <Content
    id="about"
    isReversed
    tagline="Profile"
    title="About Me & Academic Journey"
    items={[
      {
        title: 'University Specialization',
        description: 'Focused on distributed systems and data-driven application development in my second year.',
      },
      {
        title: 'Multilingual Background',
        description: 'Fluent in Arabic, French, and English, allowing for seamless collaboration in international technical environments.',
      },
      {
        title: 'Problem Solver',
        description: 'Passionate about translating complex technical concepts into efficient, automated code.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1519389950473-47ba0277781c?auto=format&fit=crop&w=2070&q=80',
      alt: 'Professional Collaboration',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Bridge between Data & Infrastructure</h3>
      I focus on creating systems that are not only functional but also scalable and highly performant.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <Steps
    title="Professional Certification Roadmap"
    items={[
      {
        title: 'Step 1: <span class="font-medium">OCI Foundations 2025</span>',
        description: "Intensive preparation for the 1Z0-1085-25 exam, focusing on core cloud concepts and OCI services.",
        icon: 'tabler:certificate',
      },
      {
        title: 'Step 2: <span class="font-medium">Data Orchestration Mastery</span>',
        description: "Advanced hands-on workshops with Apache Airflow to handle large-scale data transformation tasks.",
        icon: 'tabler:database',
      },
      {
        title: 'Step 3: <span class="font-medium">Portfolio Launch</span>',
        description: 'Deploying my professional identity using Astro and automated GitHub Pages pipelines.',
        icon: 'tabler:rocket',
      },
      {
        title: 'Ready for Internships!',
        icon: 'tabler:check',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1616198814651-e71f960c3180?auto=format&fit=crop&w=987&q=80',
      alt: 'Growth Roadmap',
    }}
  />

  <BlogLatestPosts
    id="projects"
    title="Technical Projects & Case Studies"
    information={`Explore my work in medical management statistics, Airflow ETL pipelines, and machine learning model optimization.`}
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Contact Me on LinkedIn',
        href: 'https://linkedin.com/in/YOUR-USERNAME',
        target: '_blank',
        icon: 'tabler:brand-linkedin',
      },
    ]}
  >
    <Fragment slot="title">
      Let's build something <span class="text-accent">impactful</span> together.
    </Fragment>

    <Fragment slot="subtitle">
      I am currently open to internship opportunities and collaborations in Data Engineering and Cloud Computing.
    </Fragment>
  </CallToAction>
</Layout>